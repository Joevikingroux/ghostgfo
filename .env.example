# Ghost CFO — Environment Variables
# Copy to .env and fill in all required values before running docker compose up

# ---- Application ----
APP_NAME=GhostCFO
APP_ENV=production
SECRET_KEY=
BASE_URL=https://ghostcfo.numbers10.co.za
LOG_LEVEL=INFO

# ---- PostgreSQL ----
POSTGRES_USER=ghostcfo
POSTGRES_PASSWORD=
POSTGRES_DB=ghostcfo
DATABASE_URL=postgresql+psycopg://ghostcfo:CHANGE_ME@db:5432/ghostcfo

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- OpenRouter (LLM) ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=60

# ---- WhatsApp Business Cloud API ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=
FROM_EMAIL=reports@numbers10.co.za
FROM_NAME=Ghost CFO

# ---- File Storage ----
UPLOAD_DIR=/app/uploads
REPORTS_DIR=/app/reports

# ---- Agent Security ----
AGENT_ENCRYPTION_KEY=

# ---- JWT ----
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=1440
JWT_REFRESH_DAYS=14

# ---- Payroll GL ----
PAYROLL_DB_ENABLED=false
PAYROLL_JOURNAL_GL_ACCOUNT=7100

# ---- Branding ----
BRAND_PRIMARY=#2DD4BF
BRAND_SECONDARY=#06B6D4
BRAND_FOOTER=Powered by Numbers10 Technology Solutions | numbers10.co.za
